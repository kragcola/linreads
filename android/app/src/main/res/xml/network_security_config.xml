<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext HTTP for LAN Calibre server (Android 9+ blocks cleartext by default).
  Phase 1 placeholder: add the user-configured Calibre host here, or switch to a
  runtime config. Do NOT hardcode a real baseUrl (C2).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.0.0</domain>
    </domain-config>
</network-security-config>
